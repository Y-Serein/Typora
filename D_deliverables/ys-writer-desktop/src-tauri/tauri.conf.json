{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YS Writer",
  "version": "0.1.0",
  "identifier": "com.ys.writer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YS Writer",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
